# Anthropic API key — server-side only. Never commit the real value.
# Used exclusively inside the /api routes (boss-decompose, boss-summary).
ANTHROPIC_API_KEY=

# Model used for the two real Boss API calls.
# Defaults to claude-haiku-4-5-20251001 (fast, ideal for a live demo).
# Swap in claude-sonnet-4-6 for richer Boss reasoning if a few extra
# seconds of latency is acceptable during rehearsal.
AGENT_DEMO_MODEL=claude-haiku-4-5-20251001
